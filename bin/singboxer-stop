#!/usr/bin/env bash
# singboxer-stop - Stop sing-box

set -e

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/singboxer}"
PID_FILE="$CONFIG_DIR/sing-box.pid"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Stop by PID file
stop_by_pid() {
    if [ ! -f "$PID_FILE" ]; then
        return 1
    fi

    local pid=$(cat "$PID_FILE" 2>/dev/null || echo "")
    [ -z "$pid" ] && return 1

    if kill -0 "$pid" 2>/dev/null; then
        log_info "Stopping sing-box (PID: $pid)..."
        kill "$pid" 2>/dev/null || true

        # Wait up to 5 seconds
        local count=0
        while kill -0 "$pid" 2>/dev/null && [ $count -lt 50 ]; do
            sleep 0.1
            count=$((count + 1))
        done

        # Force kill if still running
        if kill -0 "$pid" 2>/dev/null; then
            log_warn "Force killing sing-box..."
            kill -9 "$pid" 2>/dev/null || true
        fi

        rm -f "$PID_FILE"
        log_info "sing-box stopped"
        return 0
    else
        rm -f "$PID_FILE"
        return 1
    fi
}

# Stop by process name
stop_by_name() {
    local pids=$(pgrep sing-box || true)
    if [ -z "$pids" ]; then
        return 1
    fi

    log_info "Stopping sing-box processes..."
    for pid in $pids; do
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null || true
        fi
    done

    # Wait and force kill if needed
    sleep 1
    pids=$(pgrep sing-box || true)
    if [ -n "$pids" ]; then
        for pid in $pids; do
            kill -9 "$pid" 2>/dev/null || true
        done
    fi

    rm -f "$PID_FILE"
    log_info "sing-box stopped"
    return 0
}

# Main
main() {
    if stop_by_pid; then
        exit 0
    fi

    if stop_by_name; then
        exit 0
    fi

    log_warn "sing-box is not running"
    exit 0
}

main "$@"
