#!/usr/bin/env bash
# singboxer-list - List available proxies

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/singboxer}"
PROXY_CACHE="$CONFIG_DIR/proxy_cache.json"

API_PORT="${SINGBOXER_API_PORT:-9090}"
API_URL="http://127.0.0.1:$API_PORT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
NC='\033[0m'

# Get current proxy from Clash API
get_current_proxy() {
    local response=$(curl -s "$API_URL/proxies" 2>/dev/null || echo "")
    if [ -z "$response" ]; then
        echo ""
        return 1
    fi
    if command -v jq &> /dev/null; then
        echo "$response" | jq -r '.proxies.proxy.now // ""' 2>/dev/null || echo ""
    else
        echo "$response" | grep -o '"now":"[^"]*"' | cut -d'"' -f4 || echo ""
    fi
}

main() {
    if [ ! -f "$PROXY_CACHE" ]; then
        echo -e "${RED}No proxy cache found${NC}"
        echo "Run 'singboxer-start' first"
        exit 1
    fi

    if ! command -v jq &> /dev/null; then
        echo -e "${RED}jq is required${NC}"
        exit 1
    fi

    if ! command -v python3 &> /dev/null; then
        echo -e "${RED}python3 is required${NC}"
        exit 1
    fi

    local current=$(get_current_proxy)

    echo ""
    echo -e "${CYAN}=== Available Proxies ===${NC}"
    echo ""

    python3 - "$PROXY_CACHE" "$current" << 'PYTHON'
import sys, json

cache_file = sys.argv[1]
current = sys.argv[2]

with open(cache_file) as f:
    proxies = json.load(f)

for i, p in enumerate(proxies, 1):
    tag = p.get('tag', 'Unknown')
    ptype = p.get('type', 'unknown')
    server = p.get('server', 'unknown')
    port = p.get('server_port', 0)

    is_current = (tag == current)
    indicator = "* " if is_current else "  "

    # Color codes
    GREEN = '\033[0;32m'
    BLUE = '\033[0;34m'
    GRAY = '\033[0;90m'
    NC = '\033[0m'

    print(f"{indicator}{GRAY}{i:2d}){NC} {BLUE}[{ptype}]{NC} {tag} {GRAY}({server}:{port}){NC}")
PYTHON

    echo ""
    echo -e "Use: ${GREEN}singboxer-select <number>${NC} or ${GREEN}singboxer-select <name>${NC}"
    echo ""
}

main "$@"
