#!/usr/bin/env bash
# singboxer-start - Fetch subscription, generate config, start sing-box

set -e

# Config directories
CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/singboxer}"
SINGBOX_DIR="${SINGBOX_DIR:-$HOME/.config/sing-box}"
SUBSCRIPTION_FILE="$CONFIG_DIR/subscriptions.conf"
PROXY_CACHE="$CONFIG_DIR/proxy_cache.json"
CONFIG_FILE="$SINGBOX_DIR/config.json"
PID_FILE="$CONFIG_DIR/sing-box.pid"

# Ports
SOCKS_PORT="${SINGBOXER_SOCKS_PORT:-7890}"
HTTP_PORT="${SINGBOXER_HTTP_PORT:-7891}"
API_PORT="${SINGBOXER_API_PORT:-9090}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

check_singbox() {
    command -v sing-box &> /dev/null && return 0
    log_error "sing-box not found in PATH"
    log_info "Install from https://github.com/SagerNet/sing-box"
    return 1
}

check_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE" 2>/dev/null || echo "")
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            log_warn "sing-box is already running (PID: $pid)"
            return 0
        fi
        rm -f "$PID_FILE"
    fi
    return 1
}

fetch_subscription() {
    local url="$1"
    if [[ "$url" == file://* ]]; then
        local filepath="${url#file://}"
        if [ -f "$filepath" ]; then
            cat "$filepath"
            return 0
        fi
        log_error "File not found: $filepath"
        return 1
    fi
    log_info "Fetching subscription from $url"
    curl -sL --connect-timeout 10 --max-time 30 -H "User-Agent: clash" "$url"
}

decode_content() {
    local content="$1"
    if echo "$content" | tr -d '\r\n' | grep -qE '^[A-Za-z0-9+/=]+$'; then
        local decoded=$(echo "$content" | base64 -d 2>/dev/null || echo "")
        if [ -n "$decoded" ]; then
            if echo "$decoded" | head -1 | grep -qE '(proxies:|{|proxies)'; then
                echo "$decoded"
                return 0
            fi
        fi
    fi
    echo "$content"
}

# Convert Clash YAML to sing-box outbounds using Python
parse_clash_yaml() {
    local content="$1"

    python3 - "$content" << 'PYTHON'
import sys, json, yaml, re

def sanitize_tag(name):
    # Replace non-alphanumeric chars with dash
    return re.sub(r'[^a-zA-Z0-9_-]+', '-', name).strip('-')

def is_valid_server(server):
    if not server or server == 'unknown':
        return False
    # Must have dot or be IP
    if '.' not in server:
        return False
    # Filter out metadata patterns
    metadata_keywords = ['当前', '剩余', '套餐', '流量', '到期', '重置', '网址', 'url', 'expire', 'traffic']
    server_lower = server.lower()
    for kw in metadata_keywords:
        if kw in server_lower:
            return False
    # TLD check
    if '.' in server:
        tld = server.rsplit('.', 1)[-1]
        if len(tld) < 2 or len(tld) > 10 or not tld.isalpha():
            return False
    return True

try:
    data = yaml.safe_load(sys.stdin)
    proxies = data.get('proxies', [])
    outbounds = []

    for p in proxies:
        name = p.get('name', 'Unknown')
        server = p.get('server', '')
        port = p.get('port', 0)
        ptype = p.get('type', '')

        if not is_valid_server(server):
            continue
        if port < 80:
            continue

        tag = sanitize_tag(name)
        outbound = {'tag': tag, 'server': server, 'server_port': port}

        if ptype in ('ss', 'shadowsocks'):
            outbound['type'] = 'shadowsocks'
            outbound['method'] = p.get('cipher', 'aes-256-gcm')
            outbound['password'] = p.get('password', '')

        elif ptype == 'vmess':
            outbound['type'] = 'vmess'
            outbound['uuid'] = p.get('uuid', '')
            outbound['alter_id'] = p.get('alterId', 0)
            outbound['security'] = p.get('cipher', 'auto')
            outbound['network'] = p.get('network', 'tcp')
            if p.get('tls'):
                outbound['tls'] = {'enabled': True}

        elif ptype == 'vless':
            outbound['type'] = 'vless'
            outbound['uuid'] = p.get('uuid', '')
            outbound['network'] = p.get('network', 'tcp')
            if p.get('flow'):
                outbound['flow'] = p.get('flow')
            if p.get('tls'):
                outbound['tls'] = {'enabled': True}

        elif ptype == 'trojan':
            password = p.get('password', '')
            if not password:
                continue
            outbound['type'] = 'trojan'
            outbound['password'] = password
            outbound['tls'] = {'enabled': True, 'server_name': p.get('sni', server)}

        elif ptype in ('hysteria2', 'hy2'):
            outbound['type'] = 'hysteria2'
            outbound['password'] = p.get('password', '')
            outbound['tls'] = {'enabled': True, 'server_name': p.get('sni', server)}

        else:
            continue

        outbounds.append(outbound)

    print(json.dumps(outbounds, indent=2))

except Exception as e:
    print(f"Error: {e}", file=sys.stderr)
    print(json.dumps([]))
PYTHON
}

parse_clash_proxies_yq() {
    # Input is JSON from yq, convert to sing-box format using python
    python3 << 'PYTHON'
import sys, json, re

def sanitize_tag(name):
    return re.sub(r'[^a-zA-Z0-9_-]+', '-', name).strip('-')

def is_valid_server(server):
    if not server or server == 'unknown':
        return False
    if '.' not in server:
        return False
    metadata = ['当前', '剩余', '套餐', '流量', '到期', '重置', '网址', 'expire']
    return not any(m in server for m in metadata)

try:
    clash_proxies = json.load(sys.stdin)
    outbounds = []

    for p in clash_proxies:
        name = p.get('name', 'Unknown')
        server = p.get('server', '')
        port = p.get('port', 0)
        ptype = p.get('type', '')

        if not is_valid_server(server) or port < 80:
            continue

        tag = sanitize_tag(name)
        outbound = {'tag': tag, 'server': server, 'server_port': port}

        if ptype in ('ss', 'shadowsocks'):
            outbound['type'] = 'shadowsocks'
            outbound['method'] = p.get('cipher', 'aes-256-gcm')
            outbound['password'] = p.get('password', '')
        elif ptype == 'vmess':
            outbound['type'] = 'vmess'
            outbound['uuid'] = p.get('uuid', '')
            outbound['alter_id'] = p.get('alterId', 0)
            outbound['security'] = p.get('cipher', 'auto')
            outbound['network'] = p.get('network', 'tcp')
            if p.get('tls'):
                outbound['tls'] = {'enabled': True}
        elif ptype == 'vless':
            outbound['type'] = 'vless'
            outbound['uuid'] = p.get('uuid', '')
            outbound['network'] = p.get('network', 'tcp')
            if p.get('flow'):
                outbound['flow'] = p.get('flow')
            if p.get('tls'):
                outbound['tls'] = {'enabled': True}
        elif ptype == 'trojan':
            password = p.get('password', '')
            if not password:
                continue
            outbound['type'] = 'trojan'
            outbound['password'] = password
            outbound['tls'] = {'enabled': True, 'server_name': p.get('sni', server)}
        elif ptype in ('hysteria2', 'hy2'):
            outbound['type'] = 'hysteria2'
            outbound['password'] = p.get('password', '')
            outbound['tls'] = {'enabled': True, 'server_name': p.get('sni', server)}
        else:
            continue

        outbounds.append(outbound)

    print(json.dumps(outbounds, indent=2))

except Exception as e:
    print(f"Error: {e}", file=sys.stderr)
    print(json.dumps([]))
PYTHON
}

generate_config() {
    local proxies_json="$1"
    local config_file="$2"

    mkdir -p "$(dirname "$config_file")"

    python3 - "$proxies_json" "$SOCKS_PORT" "$HTTP_PORT" "$API_PORT" "$config_file" << 'PYTHON'
import sys, json

proxies_json = sys.argv[1]
socks_port = int(sys.argv[2])
http_port = int(sys.argv[3])
api_port = int(sys.argv[4])
config_file = sys.argv[5]

try:
    proxies = json.loads(proxies_json)
    if not proxies:
        print("No valid proxies found", file=sys.stderr)
        sys.exit(1)

    tags = [p['tag'] for p in proxies]
    first_tag = tags[0] if tags else 'proxy'

    config = {
        "log": {"level": "warn"},
        "inbounds": [
            {"type": "socks", "tag": "socks-in", "listen": "127.0.0.1", "listen_port": socks_port},
            {"type": "http", "tag": "http-in", "listen": "127.0.0.1", "listen_port": http_port}
        ],
        "outbounds": [
            {"type": "direct", "tag": "direct"},
            {"type": "selector", "tag": "proxy", "outbounds": tags, "default": first_tag}
        ] + proxies,
        "route": {
            "default_domain_resolver": "local-dns",
            "rules": [{"ip_is_private": True, "action": "direct"}],
            "final": "proxy",
            "auto_detect_interface": True
        },
        "dns": {
            "servers": [{"tag": "local-dns", "type": "udp", "server": "223.5.5.5"}],
            "final": "local-dns",
            "strategy": "prefer_ipv4"
        },
        "experimental": {
            "clash_api": {
                "external_controller": f"127.0.0.1:{api_port}"
            }
        }
    }

    with open(config_file, 'w') as f:
        json.dump(config, f, indent=2)

except Exception as e:
    print(f"Error generating config: {e}", file=sys.stderr)
    sys.exit(1)
PYTHON

    log_info "Config written to $config_file"
}

main() {
    check_singbox || exit 1

    if check_running; then
        exit 0
    fi

    mkdir -p "$CONFIG_DIR" "$SINGBOX_DIR"

    if [ ! -f "$SUBSCRIPTION_FILE" ]; then
        log_error "Subscription file not found: $SUBSCRIPTION_FILE"
        log_info "Create it with: echo 'https://your-subscription-url' > $SUBSCRIPTION_FILE"
        exit 1
    fi

    local url=$(grep -v '^[[:space:]]*#' "$SUBSCRIPTION_FILE" | grep -v '^$' | head -1)
    if [ -z "$url" ]; then
        log_error "No subscription URL found in $SUBSCRIPTION_FILE"
        exit 1
    fi

    if ! command -v python3 &> /dev/null; then
        log_error "python3 is required"
        exit 1
    fi

    local content=$(fetch_subscription "$url")
    if [ -z "$content" ]; then
        log_error "Failed to fetch subscription"
        exit 1
    fi

    content=$(decode_content "$content")

    # Check for Clash YAML format
    if ! echo "$content" | head -10 | grep -q 'proxies:'; then
        log_error "Unsupported subscription format"
        log_info "Please use Clash YAML format subscriptions"
        exit 1
    fi

    # Check for python3 and pyyaml or yq
    if command -v yq &> /dev/null; then
        # Use yq for parsing
        log_info "Parsing Clash YAML subscription (using yq)"
        proxies_json=$(echo "$content" | yq '.proxies // []' -o=json -I=0 2>/dev/null | parse_clash_proxies_yq)
    elif python3 -c "import yaml" 2>/dev/null; then
        # Use python3 with PyYAML
        log_info "Parsing Clash YAML subscription (using python3)"
        proxies_json=$(parse_clash_yaml "$content")
    else
        log_error "No YAML parser found"
        log_info "Install either:"
        log_info "  - yq: https://github.com/mikefarah/yq"
        log_info "  - PyYAML: pip install pyyaml"
        exit 1
    fi

    local proxy_count=$(echo "$proxies_json" | python3 -c "import sys,json; print(len(json.load(sys.stdin)))")
    log_info "Found $proxy_count proxies"

    if [ "$proxy_count" -eq 0 ]; then
        log_error "No valid proxies found in subscription"
        exit 1
    fi

    echo "$proxies_json" > "$PROXY_CACHE"
    generate_config "$proxies_json" "$CONFIG_FILE"

    log_info "Starting sing-box..."
    sing-box run -c "$CONFIG_FILE" &
    local pid=$!
    echo "$pid" > "$PID_FILE"

    sleep 1
    if kill -0 "$pid" 2>/dev/null; then
        log_info "sing-box started (PID: $pid)"
        log_info "SOCKS5: 127.0.0.1:$SOCKS_PORT"
        log_info "HTTP:   127.0.0.1:$HTTP_PORT"
        log_info "API:    127.0.0.1:$API_PORT"
        log_info "Use 'singboxer-select' to change proxy"
    else
        log_error "sing-box failed to start"
        rm -f "$PID_FILE"
        exit 1
    fi
}

main "$@"
