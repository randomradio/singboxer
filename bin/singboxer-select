#!/usr/bin/env bash
# singboxer-select - Select active proxy via Clash API

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/singboxer}"
PROXY_CACHE="$CONFIG_DIR/proxy_cache.json"

API_PORT="${SINGBOXER_API_PORT:-9090}"
API_URL="http://127.0.0.1:$API_PORT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if sing-box is running
check_running() {
    curl -s -f "$API_URL" > /dev/null 2>&1
}

# Get current proxy
get_current_proxy() {
    curl -s "$API_URL/proxies" | jq -r '.proxies.proxy.now // ""' 2>/dev/null || echo ""
}

# Sanitize name for tag
sanitize_tag() {
    echo "$1" | sed 's/[^a-zA-Z0-9_-]/-/g' | sed 's/-\+/-/g' | sed 's/^-//;s-$//'
}

# Get proxy by index
get_proxy_by_index() {
    local index="$1"

    if ! command -v jq &> /dev/null; then
        log_error "jq is required for index selection"
        exit 1
    fi

    if [ ! -f "$PROXY_CACHE" ]; then
        log_error "No proxy cache found"
        exit 1
    fi

    jq -r ".[$((index - 1))].tag // empty" "$PROXY_CACHE" 2>/dev/null
}

# Get proxy by name (fuzzy match)
get_proxy_by_name() {
    local name="$1"
    name=$(sanitize_tag "$name")

    if ! command -v jq &> /dev/null; then
        log_error "jq is required for name selection"
        exit 1
    fi

    if [ ! -f "$PROXY_CACHE" ]; then
        log_error "No proxy cache found"
        exit 1
    fi

    # Try exact match first
    local tag=$(jq -r ".[] | select(.tag == \"$name\") | .tag" "$PROXY_CACHE" 2>/dev/null | head -1)

    # Try partial match
    if [ -z "$tag" ]; then
        tag=$(jq -r ".[] | select(.tag | contains(\"$name\")) | .tag" "$PROXY_CACHE" 2>/dev/null | head -1)
    fi

    echo "$tag"
}

# Select proxy via API
select_proxy() {
    local tag="$1"

    local response=$(curl -s -X PUT "$API_URL/proxies" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"$tag\"}" 2>/dev/null)

    if [ -n "$response" ]; then
        return 0
    fi

    return 1
}

# Show usage
show_usage() {
    echo "Usage: singboxer-select <number|name>"
    echo ""
    echo "Examples:"
    echo "  singboxer-select 1        # Select first proxy"
    echo "  singboxer-select hk       # Select proxy matching 'hk'"
    echo "  singboxer-select us-01    # Select proxy with name 'us-01'"
    echo ""
    echo "Use 'singboxer-list' to see available proxies"
}

# Main
main() {
    if [ $# -eq 0 ]; then
        show_usage
        exit 1
    fi

    local selection="$1"

    # Handle help
    if [[ "$selection" == "-h" ]] || [[ "$selection" == "--help" ]]; then
        show_usage
        exit 0
    fi

    # Check if sing-box is running
    if ! check_running; then
        log_error "sing-box is not running or API is not accessible"
        log_error "Run 'singboxer-start' first"
        exit 1
    fi

    local tag=""

    # Check if selection is a number
    if [[ "$selection" =~ ^[0-9]+$ ]]; then
        tag=$(get_proxy_by_index "$selection")
        if [ -z "$tag" ]; then
            log_error "Invalid proxy number: $selection"
            exit 1
        fi
    else
        tag=$(get_proxy_by_name "$selection")
        if [ -z "$tag" ]; then
            log_error "No proxy found matching: $selection"
            exit 1
        fi
    fi

    # Select the proxy
    if select_proxy "$tag"; then
        local old=$(get_current_proxy)
        log_info "Proxy changed: $old -> $tag"
    else
        log_error "Failed to change proxy"
        exit 1
    fi
}

main "$@"
