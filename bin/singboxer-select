#!/usr/bin/env bash
# singboxer-select - Select active proxy via Clash API

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/singboxer}"
PROXY_CACHE="$CONFIG_DIR/proxy_cache.json"

API_PORT="${SINGBOXER_API_PORT:-9090}"
API_URL="http://127.0.0.1:$API_PORT"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

check_api() {
    curl -s -f "$API_URL" > /dev/null 2>&1
}

get_proxy_by_index() {
    local index="$1"
    python3 - "$PROXY_CACHE" "$index" << 'PYTHON'
import sys, json

cache_file = sys.argv[1]
index = int(sys.argv[2])

with open(cache_file) as f:
    proxies = json.load(f)

if 1 <= index <= len(proxies):
    print(proxies[index - 1]['tag'])
PYTHON
}

get_proxy_by_name() {
    local name="$1"
    python3 - "$PROXY_CACHE" "$name" << 'PYTHON'
import sys, json

cache_file = sys.argv[1]
name = sys.argv[2].lower()

with open(cache_file) as f:
    proxies = json.load(f)

for p in proxies:
    tag = p.get('tag', '')
    if name in tag.lower():
        print(tag)
        break
PYTHON
}

get_current_proxy() {
    local response=$(curl -s "$API_URL/proxies" 2>/dev/null || echo "")
    if [ -z "$response" ]; then
        echo ""
        return 1
    fi
    if command -v jq &> /dev/null; then
        echo "$response" | jq -r '.proxies.proxy.now // ""' 2>/dev/null || echo ""
    else
        echo "$response" | grep -o '"now":"[^"]*"' | cut -d'"' -f4 || echo ""
    fi
}

select_proxy() {
    local tag="$1"
    local response=$(curl -s -X PUT "$API_URL/proxies" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"$tag\"}" 2>/dev/null)
    [ -n "$response" ]
}

show_usage() {
    echo "Usage: singboxer-select <number|name>"
    echo ""
    echo "Examples:"
    echo "  singboxer-select 1        # Select first proxy"
    echo "  singboxer-select hk       # Select proxy matching 'hk'"
    echo "  singboxer-select us-01    # Select proxy with name 'us-01'"
    echo ""
    echo "Use 'singboxer-list' to see available proxies"
}

main() {
    if [ $# -eq 0 ]; then
        show_usage
        exit 1
    fi

    local selection="$1"

    if [[ "$selection" == "-h" ]] || [[ "$selection" == "--help" ]]; then
        show_usage
        exit 0
    fi

    if ! check_api; then
        log_error "sing-box is not running or API is not accessible"
        log_error "Run 'singboxer-start' first"
        exit 1
    fi

    if ! command -v python3 &> /dev/null; then
        log_error "python3 is required"
        exit 1
    fi

    local tag=""

    if [[ "$selection" =~ ^[0-9]+$ ]]; then
        tag=$(get_proxy_by_index "$selection")
        if [ -z "$tag" ]; then
            log_error "Invalid proxy number: $selection"
            exit 1
        fi
    else
        tag=$(get_proxy_by_name "$selection")
        if [ -z "$tag" ]; then
            log_error "No proxy found matching: $selection"
            exit 1
        fi
    fi

    local old=$(get_current_proxy)
    if select_proxy "$tag"; then
        log_info "Proxy changed: $old -> $tag"
    else
        log_error "Failed to change proxy"
        exit 1
    fi
}

main "$@"
